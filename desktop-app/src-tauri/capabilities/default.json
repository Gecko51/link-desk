{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and overlay",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-set-always-on-top"
  ]
}
